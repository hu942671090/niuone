# Copy this file to dashboard.env for local production-style runs.
# Keep dashboard.env private; it may contain secrets and absolute local paths.

DASHBOARD_HOME=/absolute/path/to/NiuOne/.local-data/runtime
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8787
PYTHON_BIN=python3

DASHBOARD_CONFIG=/absolute/path/to/NiuOne/.local-data/runtime/config.yaml
DASHBOARD_PUSH_HISTORY_DB=/absolute/path/to/NiuOne/.local-data/runtime/push_history.db
DASHBOARD_PORTFOLIO_STATE=/absolute/path/to/NiuOne/.local-data/runtime/cron/output/niuniu_practice_portfolio.json
DASHBOARD_TRADER_SCRIPT=/absolute/path/to/NiuOne/app/niuniu_practice_trader.py

DASHBOARD_AUTH_ENABLED=1
DASHBOARD_ADMIN_PASSWORD=
DASHBOARD_AUTH_TOUCH_INTERVAL_SECONDS=30

DASHBOARD_EDGE_CACHE_ENABLED=0
DASHBOARD_RATE_LIMIT_ENABLED=1
DASHBOARD_RATE_LIMIT_ANON=240
DASHBOARD_RATE_LIMIT_AUTH=900
DASHBOARD_RATE_LIMIT_LOGIN=20
DASHBOARD_RATE_LIMIT_ADMIN=90

DASHBOARD_B1_SCHEDULE_TIMES=09:25,10:00,10:30,11:00,11:20,13:00,13:30,14:00,14:30,14:50
DASHBOARD_DECISION_MAX_TOKENS=6000
DASHBOARD_DECISION_TIMEOUT=180
DASHBOARD_US_FEATURES_ENABLED=0
DASHBOARD_GROK_MODEL=grok-4.20-multi-agent-xhigh
DASHBOARD_NEWS_MODEL=
DASHBOARD_NEWS_BASE_URL=
DASHBOARD_NEWS_API_KEY=
DASHBOARD_DECISION_MODEL=deepseek-v4-pro

DASHBOARD_MARKET_AUCTION_CRON="25 9 * * 1-5"
DASHBOARD_MARKET_MIDDAY_CRON="40 11 * * 1-5"
DASHBOARD_MARKET_CLOSE_CRON="10 15 * * 1-5"
X_WATCHLIST_DAEMON_INTERVAL_SECONDS=1200
DASHBOARD_US_RATING_CRON="0 11 * * *"
DASHBOARD_INDICES_TTL_SECONDS=60
